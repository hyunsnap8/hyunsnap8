/**********************************************************************
 *  현스냅 · 셀렉 접수 웹앱 (doPost)
 *  ──────────────────────────────────────────────────────────────────
 *  손님이 셀렉 폼에서 올린 사진(JPG)을 구글 드라이브에 저장합니다.
 *
 *  저장 위치 (사진이 폴더에 차곡차곡 쌓입니다)
 *    [셀렉폴더] ─┬─ 돌셀렉  ── "행사일 이름" 폴더 ── 사진들
 *               └─ 신부셀렉 ── "행사일 이름" 폴더 ── 사진들
 *    예) 셀렉폴더 / 신부셀렉 / 260220 홍길동 / IMG_0001.jpg ...
 *
 *  ✅ 하는 일  : 폴더 만들기 / 사진 저장 / (선택)접수 로그
 *  🚫 안 하는 일 : 파일·폴더 삭제, 이동, 덮어쓰기 (절대 안 함)
 *  같은 이름 파일이 이미 있으면 저장하지 않고 '건너뜀' 처리합니다.
 *
 *  ── 처음 쓰는 순서 ──────────────────────────────────────────────
 *   1) 아래 '셀렉상위폴더ID'가 맞는지 확인 (지금은 사장님이 만든 셀렉폴더로 넣어둠)
 *   2) 편집기 상단 [배포] → [새 배포] → 유형 '웹 앱'
 *        - 실행 계정: 나
 *        - 액세스 권한: '모든 사용자'
 *      → 배포하면 나오는 .../exec 주소를 복사
 *   3) 그 주소를 현스냅_셀렉접수폼.html 의  const 전송주소 = "여기"  에 붙여넣기
 **********************************************************************/


/* ===================== 설정 (여기만 손대면 됩니다) ===================== */
var 셀렉설정 = {
  // 신부셀렉·돌셀렉이 들어있는 '셀렉폴더'의 ID
  //   (드라이브에서 폴더 열기 → 주소창 .../folders/ 뒤의 글자들이 ID)
  셀렉상위폴더ID: "1VYan6dp4t8ms0m0SNLXhRCPl8ySheqA5",

  // 셀렉폴더 안 '실제 폴더 이름'과 똑같이 적어야 새 폴더가 안 생깁니다.
  //   (드라이브의 "1. 현스냅 셀렉 / 2. 돌 셀렉 / 3. 피치스냅 셀렉" 와 글자·띄어쓰기까지 일치)
  신부폴더명: "1. 현스냅 셀렉",
  돌폴더명:   "2. 돌 셀렉",
  피치폴더명: "3. 피치스냅 셀렉",

  // (선택) 접수 기록을 남길 구글시트 ID. 비워두면 기록 안 함(저장은 정상 동작).
  //   시트 주소 .../d/여기가ID/edit
  로그시트ID: ""
};
/* ===================================================================== */


/* ---------- 폼이 보낸 사진을 받는 입구 (자동 호출) ---------- */
function doPost(e){
  try{
    var p = JSON.parse(e.postData.contents);   // 폼이 보낸 정보(JSON)

    var 분류   = 분류폴더구하기(p.type);            // {폴더, 이름}
    var 이름   = 글자정리(p.name || "이름없음");
    var 행사일 = 여섯자리날짜(p.date || "");
    var 폴더명 = (행사일 ? 행사일 + " " : "") + 이름;   // 예) "260220 홍길동"
    var 파일이름 = 파일명정리(p.filename || "사진.jpg");

    // [분류 폴더(신부셀렉/돌셀렉/피치)] → [행사일 이름] (없으면 만들고, 있으면 그대로 → 쌓임)
    var 대상폴더 = 폴더가져오기또는생성(분류.폴더, 폴더명);

    // 참고사진 등은 하위폴더(sub)로 분리 저장 (예: 행사일 이름 / 참고사진)
    if (p.sub) {
      대상폴더 = 폴더가져오기또는생성(대상폴더, 글자정리(p.sub));
    }

    // 같은 이름이 이미 있으면 건너뜀 (덮어쓰기·삭제 절대 안 함)
    var 결과;
    if (대상폴더.getFilesByName(파일이름).hasNext()){
      결과 = "건너뜀(이미있음)";
    } else {
      var bytes = Utilities.base64Decode(p.b64);
      var blob  = Utilities.newBlob(bytes, "image/jpeg", 파일이름);
      대상폴더.createFile(blob);
      결과 = "저장";
    }

    로그기록([new Date(), 분류.이름, 폴더명, 파일이름, 결과, (p.index||"") + "/" + (p.total||"")]);
    return 응답({ok:true, result:결과, folder:분류.이름 + " / " + 폴더명, file:파일이름});

  }catch(err){
    로그기록([new Date(), "오류", "", "", String(err), ""]);
    return 응답({ok:false, error:String(err)});
  }
}


/* ---------- 브라우저에서 주소를 그냥 열었을 때(점검용) ---------- */
function doGet(){
  return 응답({ok:true, msg:"현스냅 셀렉 접수 웹앱이 살아있습니다."});
}


/* ===================== 아래는 손대지 않아도 됩니다 ===================== */

// 종류(돌/신부/피치) → 저장할 분류 폴더를 돌려줌 {폴더, 이름}
//   모두 셀렉폴더 안의 하위폴더로 저장
//   돌 → 2. 돌 셀렉 / 피치 → 3. 피치스냅 셀렉 / 그 외(신부 등) → 1. 현스냅 셀렉
function 분류폴더구하기(t){
  var s = String(t || "").toLowerCase();
  var 셀렉폴더 = DriveApp.getFolderById(셀렉설정.셀렉상위폴더ID);

  var 이름;
  if (s.indexOf("돌") >= 0 || s === "dol" || s === "baby" || s === "first"){
    이름 = 셀렉설정.돌폴더명;
  } else if (s.indexOf("피치") >= 0 || s === "peach" || s === "pitch" || s === "pittch"){
    이름 = 셀렉설정.피치폴더명;
  } else {
    이름 = 셀렉설정.신부폴더명;
  }
  return { 폴더: 폴더가져오기또는생성(셀렉폴더, 이름), 이름: 이름 };
}

// 행사일을 6자리(YYMMDD)로. 예) "2026-02-20" → "260220", "260220" → 그대로
function 여섯자리날짜(s){
  var d = String(s).replace(/\D/g, "");
  if (d.length === 8) return d.slice(2);   // YYYYMMDD → YYMMDD
  if (d.length === 6) return d;            // 이미 YYMMDD
  return String(s).trim();                 // 그 외엔 받은 그대로
}

// 폴더 이름에 못 쓰는 문자 정리
function 글자정리(s){
  return String(s).replace(/[\\\/:*?"<>|]/g, " ").replace(/\s+/g, " ").trim() || "이름없음";
}

// 파일 이름에서 경로문자만 정리 (이름 자체는 손님이 올린 그대로 보존)
function 파일명정리(s){
  return String(s).replace(/[\\\/:*?"<>|]/g, "_").trim() || "사진.jpg";
}

// 같은 이름 폴더가 있으면 그대로 쓰고, 없으면 새로 만듦 (중복 폴더 방지 → 쌓임)
function 폴더가져오기또는생성(상위, 이름){
  var it = 상위.getFoldersByName(이름);
  return it.hasNext() ? it.next() : 상위.createFolder(이름);
}

// (선택) 접수 기록을 구글시트에 한 줄 추가. 로그시트ID 비어있으면 조용히 건너뜀.
function 로그기록(행){
  try{
    if (!셀렉설정.로그시트ID) return;
    var ss = SpreadsheetApp.openById(셀렉설정.로그시트ID);
    var sh = ss.getSheetByName("셀렉접수로그") || ss.insertSheet("셀렉접수로그");
    if (sh.getLastRow() === 0){
      sh.appendRow(["접수시각", "분류", "폴더명(행사일 이름)", "파일명", "결과", "장수(N/총)"]);
    }
    sh.appendRow(행);
  }catch(e){ /* 기록 실패해도 저장은 정상 진행 */ }
}

// JSON으로 응답
function 응답(obj){
  return ContentService
    .createTextOutput(JSON.stringify(obj))
    .setMimeType(ContentService.MimeType.JSON);
}
